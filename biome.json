{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "assist": {
    "actions": {
      "source": {
        "useSortedAttributes": "on",
        "useSortedInterfaceMembers": "on",
        "useSortedKeys": "on"
      }
    }
  },
  "files": {
    "includes": ["src/**"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "nursery": {
        "noContinue": "error",
        "noDivRegex": "error",
        "noDuplicateVariableNames": "error",
        "useExplicitType": "error"
      },
      "recommended": true,
      "style": {
        "useConsistentArrayType": {
          "level": "warn",
          "options": {
            "syntax": "shorthand"
          }
        },
        "useNamingConvention": {
          "level": "warn",
          "options": {
            "conventions": [
              {
                "formats": ["camelCase"],
                "selector": { "kind": "variable" }
              },
              {
                "formats": ["camelCase"],
                "selector": { "kind": "function" }
              },
              {
                "formats": ["PascalCase"],
                "selector": { "kind": "typeLike" }
              },
              {
                "formats": ["camelCase", "snake_case", "CONSTANT_CASE"],
                "selector": { "kind": "typeProperty" }
              },
              {
                "formats": [
                  "camelCase",
                  "snake_case",
                  "PascalCase",
                  "CONSTANT_CASE"
                ],
                "selector": { "kind": "objectLiteralProperty" }
              }
            ],
            "strictCase": false
          }
        }
      }
    }
  }
}
