{
	"name": "prox3",
	"version": "1.0.0",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "bun build . --compile --bytecode --format=esm --minify --target bun --sourcemap --outfile dist/prox3",
		"start": "./dist/prox3",
		"ci/cd": "biome check . --error-on-warnings",
		"lint": "biome check . --fix && biome format . --write",
		"lint:unsafe": "biome check . --fix --unsafe && biome format . --write",
		"dev": "bun run --watch ."
	},
	"dependencies": {
		"@elysia/openapi": "^1.4.15",
		"elysia": "^1.4.28"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/bun": "^1.3.14",
		"typescript": "^6.0.3"
	}
}
